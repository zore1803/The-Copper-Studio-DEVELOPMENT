# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
JWT_SECRET=change-this-long-random-secret
CRM_PUBLIC_URL=http://localhost:5173

# Keep-warm: set to the deployed service's own public /api/health URL so the
# server pings itself and the free hosting tier never sleeps (avoids the 50s+
# cold-start). Leave blank locally. Interval defaults to 10 min.
KEEP_ALIVE_URL=
KEEP_ALIVE_INTERVAL_MS=600000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/datacircles

# ─── Superadmin seed account ──────────────────────────────────────────────────
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=admin@copperstudio.com
SUPERADMIN_PASSWORD=admin@123

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ─── Email — SendGrid ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
MAIL_FROM_EMAIL=no-reply@yourdomain.com
MAIL_FROM_NAME=The Copper Studio

# ─── SMS — Fast2SMS ───────────────────────────────────────────────────────────
FAST2SMS_API_KEY=your-fast2sms-api-key
SENDER_ID=YOURID
DLT_TEMPLATE_ID=your-dlt-template-id

# ─── Calendly ─────────────────────────────────────────────────────────────────
Calendly_Access_Token=your-calendly-personal-access-token

# ─── Google People API (guest name lookup) ────────────────────────────────────
# Used to resolve a meeting guest's display name from just their email, the
# way Gmail's "To" field does — via the authorized mailbox's Contacts / mail
# history. One-time setup: create an OAuth client in Google Cloud Console
# (People API enabled), set the three vars below, then visit
# GET /api/google/auth-url as a superadmin, approve access, and copy the
# refresh token it prints into GOOGLE_OAUTH_REFRESH_TOKEN.
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/google/oauth/callback
GOOGLE_OAUTH_REFRESH_TOKEN=

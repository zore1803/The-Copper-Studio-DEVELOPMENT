# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
JWT_SECRET=change-this-long-random-secret
CRM_PUBLIC_URL=http://localhost:5173

# ─── Database driver ──────────────────────────────────────────────────────────
# "mongo" or "supabase" — flip this one value to switch the whole backend.
DB_DRIVER=supabase

# ─── MongoDB (used when DB_DRIVER=mongo) ──────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/datacircles

# ─── Supabase (used when DB_DRIVER=supabase) ─────────────────────────────────
SUPABASE_ID=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
SUPABASE_ANON_KEY=your-anon-jwt-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-here

# Optional boot-check tuning
SUPABASE_BOOT_CHECK_TIMEOUT_MS=8000
STRICT_SUPABASE_BOOT_CHECK=false
SUPABASE_CHECK_TIMEOUT_MS=10000

# ─── Superadmin seed account ──────────────────────────────────────────────────
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ChangeMe123!

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ─── Email — SendGrid ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
MAIL_FROM_EMAIL=no-reply@yourdomain.com
MAIL_FROM_NAME=The Copper Studio

# ─── SMS — Fast2SMS ───────────────────────────────────────────────────────────
FAST2SMS_API_KEY=your-fast2sms-api-key
SENDER_ID=YOURID
DLT_TEMPLATE_ID=your-dlt-template-id

# ─── Calendly ─────────────────────────────────────────────────────────────────
Calendly_Access_Token=your-calendly-personal-access-token

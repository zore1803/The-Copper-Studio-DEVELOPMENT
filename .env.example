PORT=5000
JWT_SECRET=change-this-long-random-secret
CRM_PUBLIC_URL=http://localhost:5173

# Which database backend to use: "mongo" (default) or "supabase".
# Flip this one value to switch the whole app between Supabase and MongoDB.
DB_DRIVER=mongo

# Database: MongoDB.
MONGO_URI=mongodb://127.0.0.1:27017/datacircles

# Optional: Supabase (hosted Postgres). Needed only when DB_DRIVER=supabase or
# when running the Supabase migration scripts.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BOOT_CHECK_TIMEOUT_MS=8000
STRICT_SUPABASE_BOOT_CHECK=false
SUPABASE_CHECK_TIMEOUT_MS=10000

# Migration scripts:
#   npm run migrate:supabase
#   npm run migrate:to-mongo

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=admin@datacircles.local
SUPERADMIN_PASSWORD=ChangeMe123!

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM=DataCircles CRM <your-email@gmail.com>

CALENDLY_ACCESS_TOKEN=
CALENDLY_WEBHOOK_SIGNING_KEY=


#http://localhost:5000/pricing returns the pricing HTML.
#http://localhost:5000/checkout returns the checkout HTML.
#http://localhost:5173/client-secure-onboarding/access-setup returns the CRM app.
